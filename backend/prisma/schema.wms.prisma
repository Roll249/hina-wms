// ============================================================
// Hina WMS - Prisma Schema
// ============================================================
// File này KHÔNG định nghĩa schema database. Schema thực tế được
// quản lý bởi project hina-e-comm (Prisma migrate).
//
// File này chỉ chứa các model WMS mở rộng, dùng để generate
// Prisma Client cho WMS backend. Khi schema gốc của hina-e-comm
// thay đổi, cần:
//   1. Cập nhật schema.gốc bên hina-e-comm
//   2. Pull lại schema vào file schema.hina.prisma (xem scripts/sync-schema.sh)
//   3. Merge với phần WMS bên dưới
//
// Hoặc đơn giản hơn: copy schema gốc + phần WMS bên dưới vào file
// schema.prisma trong prisma/, sau đó chạy `prisma generate`.
// ============================================================

generator client {
  provider = "prisma-client-js"
  output   = "../node_modules/.prisma/client"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ============================================================
// ENUMS MỚI (WMS-specific)
// ============================================================

enum GoodsReceiptStatus {
  DRAFT
  CONFIRMED
  CANCELLED
}

enum ReceiptSource {
  MANUAL
  BARCODE
  FILE
}

enum ShipmentStatus {
  PENDING
  PICKING
  PICKED
  PACKING
  PACKED
  HANDED_OVER
  CANCELLED
}

// ============================================================
// MODELS MỚI (WMS-specific)
// ============================================================

model Warehouse {
  id        String   @id @default(uuid())
  code      String   @unique
  name      String
  address   String?
  isDefault Boolean  @default(false)
  isActive  Boolean  @default(true)

  staff     WarehouseStaff[]
  receipts  GoodsReceipt[]
  shipments OutboundShipment[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Supplier {
  id            String   @id @default(uuid())
  code          String?  @unique
  name          String
  contactPerson String?
  phone         String?
  email         String?
  address       String?
  isActive      Boolean  @default(true)

  receipts      GoodsReceipt[]

  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
}

model WarehouseStaff {
  id           String   @id @default(uuid())
  userId       String   @unique
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  employeeCode String   @unique
  warehouseId  String
  warehouse    Warehouse @relation(fields: [warehouseId], references: [id])
  pinHash      String?
  isActive     Boolean  @default(true)

  receipts     GoodsReceipt[]      @relation("ReceivedBy")
  shipments    OutboundShipment[]  @relation("PickedBy")
  movements    InventoryMovement[]

  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  @@index([warehouseId])
  @@index([employeeCode])
}

model GoodsReceipt {
  id            String   @id @default(uuid())
  receiptNumber String   @unique
  warehouseId   String
  warehouse     Warehouse @relation(fields: [warehouseId], references: [id])
  supplierId    String?
  supplier      Supplier? @relation(fields: [supplierId], references: [id])
  receivedById  String
  receivedBy    WarehouseStaff @relation("ReceivedBy", fields: [receivedById], references: [id])
  status        GoodsReceiptStatus @default(DRAFT)
  source        ReceiptSource      @default(MANUAL)
  note          String?
  totalQuantity Int      @default(0)
  totalSku      Int      @default(0)
  completedAt   DateTime?
  cancelledAt   DateTime?

  items         GoodsReceiptItem[]

  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  @@index([warehouseId, createdAt])
  @@index([status])
  @@index([receivedById])
}

model GoodsReceiptItem {
  id               String   @id @default(uuid())
  receiptId        String
  receipt          GoodsReceipt @relation(fields: [receiptId], references: [id], onDelete: Cascade)

  productId        String?
  variantId        String?
  product          Product?       @relation(fields: [productId], references: [id], onDelete: SetNull)
  variant          ProductVariant? @relation(fields: [variantId], references: [id], onDelete: SetNull)

  productCode      String
  productName      String
  sku              String

  expectedQuantity Int      @default(0)
  receivedQuantity Int      @default(0)
  unitCost         Decimal? @db.Decimal(12, 2)
  lotNumber        String?
  expiryDate       DateTime?
  note             String?

  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  @@index([receiptId])
  @@index([productId])
  @@index([variantId])
  @@index([productCode])
}

model OutboundShipment {
  id             String   @id @default(uuid())
  shipmentNumber String   @unique
  orderId        String
  orderNumber    String
  warehouseId    String
  warehouse      Warehouse @relation(fields: [warehouseId], references: [id])
  pickedById     String?
  pickedBy       WarehouseStaff? @relation("PickedBy", fields: [pickedById], references: [id])
  status         ShipmentStatus  @default(PENDING)
  pickedAt       DateTime?
  packedAt       DateTime?
  handedOverAt   DateTime?
  carrierName    String?
  trackingNumber String?
  note           String?

  items          OutboundShipmentItem[]

  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  @@unique([orderId])
  @@index([warehouseId, status])
  @@index([pickedById])
}

model OutboundShipmentItem {
  id            String   @id @default(uuid())
  shipmentId    String
  shipment      OutboundShipment @relation(fields: [shipmentId], references: [id], onDelete: Cascade)

  productId     String?
  variantId     String?
  product       Product?       @relation(fields: [productId], references: [id], onDelete: SetNull)
  variant       ProductVariant? @relation(fields: [variantId], references: [id], onDelete: SetNull)

  productCode   String
  productName   String
  sku           String
  orderQuantity Int
  pickedQuantity Int     @default(0)
  packedQuantity Int     @default(0)

  @@index([shipmentId])
  @@index([productId])
  @@index([variantId])
}
