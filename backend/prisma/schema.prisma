generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum Role {
  GUEST
  RETAIL
  WHOLESALE
  CTV
  MANAGE
  ADMIN
}

enum AddressType {
  BILLING
  SHIPPING
  COMPANY_OFFICE
  DELIVERY
}

enum ManagePermissionType {
  MANAGE_PRODUCTS
  MANAGE_INVENTORY
  MANAGE_ORDERS
  MANAGE_CUSTOMERS
  APPROVE_WHOLESALE
  MANAGE_CTV
  VIEW_REPORTS
  APPROVE_DISCOUNT
  APPROVE_INVOICE
  MANAGE_WHOLESALE_PRICES
  MANAGE_CUSTOMER_DISCOUNTS // Set customer maxDiscountPct
}

enum OrderStatus {
  PENDING
  CONFIRMED
  PROCESSING
  DELIVERED
  COMPLETED
  CANCELLED
  REFUNDED
}

enum PaymentMethod {
  COD
  BANK_TRANSFER
}

enum PaymentProvider {
  STRIPE
  PAYPAL
  VIETQR
}

enum PaymentStatus {
  PENDING
  PAID
  FAILED
  REFUNDED
}

enum PaymentAttemptStatus {
  PENDING
  PAID
  FAILED
  EXPIRED
  CANCELLED
}

enum InvoiceStatus {
  NOT_REQUESTED
  REQUESTED
  APPROVED
  REJECTED
  ISSUED
}

enum InvoiceRecordStatus {
  DRAFT
  ISSUED
  CANCELLED
}

enum MovementType {
  PRODUCT_CREATED
  VARIANT_CREATED
  STOCK_INITIALIZED
  STOCK_SET_MANUAL
  STOCK_ADJUSTED_MANUAL
  STOCK_DEDUCTED_ORDER
  STOCK_RESTORED_ORDER_CANCEL
  STOCK_RESERVED
  STOCK_RELEASED
  STOCK_RELEASED_ABANDONED
  RETURN
  SHIPMENT
  GOODS_RECEIPT
  ORDER_SHIPMENT
  STOCKTAKE_ADJUST
}

enum ProductVisibility {
  PUBLIC      // Everyone sees
  WHOLESALE  // Wholesale + Admin only
  RETAIL      // Retail + Admin only
  BOTH        // Wholesale + Retail
  HIDDEN      // Admin only
}

enum CustomerType {
  WHOLESALE
  RETAIL
}

enum AuditAction {
  CREATE
  UPDATE
  DELETE
  LOGIN
  LOGOUT
  APPROVE
  REJECT
  CANCEL
}

enum WithdrawalStatus {
  PENDING
  APPROVED
  REJECTED
}

enum PayoutStatus {
  PAID
  REVERSED
}

model SystemConfig {
  id        String   @id @default(uuid())
  key       String   @unique
  value     String
  updatedAt DateTime @updatedAt
  updatedBy String?
}

model User {
  id         String    @id @default(uuid())
  email      String    @unique
  name       String?
  password   String
  role       Role      @default(RETAIL)
  isActive   Boolean   @default(false)
  warehouseStaff WarehouseStaff?
  permissionMask BigInt @default(0)
  approvedAt DateTime?
  approvedBy String?

  avatar      String?  // S3 URL for profile picture

  // Wholesale business fields
  ico         String?
  dic         String?

  // Soft delete for D-04
  deletedAt   DateTime?

  createdAt   DateTime      @default(now())
  updatedAt   DateTime      @updatedAt
  refreshTokens RefreshToken[]

  // Relations to role-specific models
  address        Address[]
  wholesaleCustomer WholesaleCustomer?
  ctvCustomer    CtvCustomer?
  managePermissions ManagePermission[]
  cart           Cart?
  orders         Order[]
  createdPermissionPresets PermissionPreset[] @relation("PermissionPresetCreatedBy")
  updatedPermissionPresets PermissionPreset[] @relation("PermissionPresetUpdatedBy")

  @@index([email])
  @@index([role])
  @@index([permissionMask])
  @@index([deletedAt])
  @@index([deletedAt, createdAt])
}

model PermissionPreset {
  id             String   @id @default(uuid())
  name           String
  description    String?
  permissionMask BigInt   @default(0)
  sortOrder      Int      @default(0)
  createdById    String?
  updatedById    String?
  createdBy      User?    @relation("PermissionPresetCreatedBy", fields: [createdById], references: [id], onDelete: SetNull)
  updatedBy      User?    @relation("PermissionPresetUpdatedBy", fields: [updatedById], references: [id], onDelete: SetNull)
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  @@unique([name])
  @@index([sortOrder])
  @@index([createdById])
  @@index([updatedById])
}

model RefreshToken {
  id        String   @id @default(uuid())
  token     String   @unique
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  expiresAt DateTime
  isRevoked Boolean  @default(false)
  createdAt DateTime @default(now())

  @@index([token])
  @@index([userId])
}

model Address {
  id          String       @id @default(uuid())
  userId      String
  type        AddressType  @default(SHIPPING)
  label       String?
  name        String
  phone       String
  street      String
  ward        String?
  district    String?
  city        String
  province    String
  country     String       @default("Vietnam")
  postalCode  String?
  isDefault   Boolean      @default(false)

  user        User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt

  @@index([userId])
  @@index([userId, type])
}

model WholesaleCustomer {
  id                String    @id @default(uuid())
  userId            String    @unique
  businessName      String
  businessType      String?
  taxId             String?
  ico               String?
  dic               String?
  contactPerson     String?
  businessPhone     String?
  businessLicense   String?
  creditLimit       Decimal?  @db.Decimal(12, 2)
  paymentTerms      String?

  // Max discount this customer can receive (managed by Admin/Manage)
  maxDiscountPct   Decimal   @default(0) @db.Decimal(5, 2)

  user              User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  // CTV assignments to this customer
  assignedCtvs      CtvAssignment[]

  // Orders created by CTVs for this customer (for visibility)
  orders            Order[]

  approvedBy        String?
  approvedAt        DateTime?
  rejectedAt        DateTime?
  rejectionReason   String?
  createdAt         DateTime  @default(now())
  updatedAt         DateTime  @updatedAt

  @@index([userId])
  @@index([approvedAt])
}

model CtvCustomer {
  id                String    @id @default(uuid())
  userId            String    @unique
  employeeCode      String?   @unique
  department        String?
  commissionFeePct  Decimal   @default(0) @db.Decimal(5, 2)
  // Whether CTV can create wholesale customer accounts
  canCreateCustomer Boolean   @default(false)

  user              User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  // CTVs are assigned to specific wholesale customers
  assignedCustomers CtvAssignment[]

  // Orders created by this CTV
  orders           Order[]

  // Withdrawal and payout records
  withdrawalRequests CtvWithdrawalRequest[]
  payouts           CtvPayout[]

  // Bank account fields (PAY-03)
  bankName            String?
  bankAccountNumber   String?
  bankAccountHolder   String?

  createdAt         DateTime  @default(now())
  updatedAt         DateTime  @updatedAt

  @@index([userId])
  @@index([employeeCode])
}

// Links CTV to specific wholesale customers they can create orders for
model CtvAssignment {
  id               String            @id @default(uuid())
  ctvId            String
  wholesaleCustomerId String
  assignedBy       String            // userId who made the assignment
  assignedAt       DateTime         @default(now())
  isActive         Boolean          @default(true)

  ctv              CtvCustomer       @relation(fields: [ctvId], references: [id], onDelete: Cascade)
  wholesaleCustomer WholesaleCustomer @relation(fields: [wholesaleCustomerId], references: [id], onDelete: Cascade)

  @@unique([ctvId, wholesaleCustomerId])
  @@index([ctvId])
  @@index([wholesaleCustomerId])
}

model ManagePermission {
  id          String                 @id @default(uuid())
  userId      String
  permission  ManagePermissionType
  grantedBy   String
  expiresAt   DateTime?
  note        String?

  user        User                   @relation(fields: [userId], references: [id], onDelete: Cascade)
  createdAt   DateTime               @default(now())

  @@unique([userId, permission])
  @@index([userId])
  @@index([permission])
}

model Category {
  id          String     @id @default(uuid())
  slug        String     @unique
  parentId    String?
  name        String
  description String?

  icon        String?
  imageUrl    String?
  bannerImageUrl String?
  taxRate     Decimal?   @db.Decimal(5, 4)
  sortOrder   Int        @default(0)
  isActive    Boolean    @default(true)

  // Storefront placement flags
  showOnMegaMenu Boolean @default(false)
  showOnHomepageCard Boolean @default(false)
  megaMenuSortOrder Int?
  homepageCardSortOrder Int?

  products    Product[]
  parent      Category?  @relation("CategoryHierarchy", fields: [parentId], references: [id], onDelete: SetNull)
  children    Category[] @relation("CategoryHierarchy")

  createdAt   DateTime   @default(now())
  updatedAt   DateTime   @updatedAt
  deletedAt   DateTime?

  @@index([slug])
  @@index([isActive])
  @@index([parentId])
  @@index([showOnMegaMenu, megaMenuSortOrder])
  @@index([showOnHomepageCard, homepageCardSortOrder])
}

model StorefrontHeroSlide {
  id            String   @id @default(uuid())
  imageKey      String
  titleVi       String?
  titleEn       String?
  titleCs       String?
  descriptionVi String?
  descriptionEn String?
  descriptionCs String?
  sortOrder     Int      @default(0)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  @@index([sortOrder])
}

model Cart {
  id          String     @id @default(uuid())
  userId      String?
  sessionId   String?
  guestToken  String?    @unique  // UUID from localStorage, for guest carts

  user        User?      @relation(fields: [userId], references: [id], onDelete: SetNull)
  items       CartItem[]

  createdAt   DateTime   @default(now())
  updatedAt   DateTime   @updatedAt
  expiresAt   DateTime?

  @@unique([userId])
  @@unique([sessionId])
  @@index([userId])
  @@index([sessionId])
}

model CartItem {
  id          String   @id @default(uuid())
  cartId      String
  productId   String
  variantId   String?
  quantity    Int      @default(1)

  cart        Cart     @relation(fields: [cartId], references: [id], onDelete: Cascade)
  product     Product  @relation(fields: [productId], references: [id], onDelete: Cascade)
  variant     ProductVariant? @relation(fields: [variantId], references: [id], onDelete: SetNull)

  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@unique([cartId, productId, variantId])
  @@index([cartId])
  @@index([productId])
}

model Order {
  id              String         @id @default(uuid())
  orderNumber     String         @unique  // Format: WB-2026-00001

  // Customer who requested/owns the order
  customerId      String
  customer        User           @relation(fields: [customerId], references: [id])

  // Wholesale customer account (if order is for a wholesale customer)
  // Used for: visibility in wholesale account, pricing lookup
  wholesaleCustomerId String?
  wholesaleCustomer WholesaleCustomer? @relation(fields: [wholesaleCustomerId], references: [id])

  // CTV who created the order (null if customer ordered directly)
  ctvId           String?
  ctv             CtvCustomer?   @relation(fields: [ctvId], references: [id])

  // Address snapshots stored as JSON (per D-03)
  shippingAddress Json
  billingAddress  Json?

  // Opposite relations
  items           OrderItem[]
  invoice         Invoice?
  statusHistory   OrderStatusHistory[]
  paymentAttempts PaymentAttempt[]

  // Pricing
  subtotal        Decimal        @db.Decimal(14, 2)
  discountAmount  Decimal        @db.Decimal(14, 2) @default(0)
  shippingCost    Decimal        @db.Decimal(14, 2) @default(0)
  taxAmount       Decimal        @db.Decimal(14, 2) @default(0)
  total           Decimal        @db.Decimal(14, 2)

  ctvCommissionPct    Decimal?      @db.Decimal(5, 2)
  ctvCommissionAmount Decimal?      @db.Decimal(14, 2)
  ctvCommissionClaimed Boolean     @default(false)

  // Guest order flag (orders placed without registration)
  isGuestOrder    Boolean         @default(false)

  // Status
  status          OrderStatus    @default(PENDING)

  // Payment
  paymentMethod   PaymentMethod?
  paymentStatus   PaymentStatus  @default(PENDING)
  paymentId       String?
  paidAt          DateTime?

  // Notes
  customerNote    String?
  adminNote       String?

  // Invoice
  invoiceRequested Boolean      @default(false)
  invoiceStatus    InvoiceStatus?
  // Separate invoice number (admin can set a custom invoice number)
  invoiceNumber    String?       @unique
  // Invoice date (can be set independently of order date)
  invoiceDate      DateTime?

  // Timestamps
  createdAt       DateTime       @default(now())
  updatedAt       DateTime       @updatedAt
  completedAt     DateTime?
  cancelledAt     DateTime?
  cancelledBy     String?
  cancellationReason String?

  @@index([customerId])
  @@index([customerId, createdAt])
  @@index([wholesaleCustomerId])
  @@index([wholesaleCustomerId, status, createdAt])
  @@index([ctvId])
  @@index([ctvId, createdAt])
  @@index([orderNumber])
  @@index([status])
  @@index([status, createdAt])
  @@index([createdAt])
  @@index([ctvId, status, ctvCommissionClaimed])
}

model PaymentAttempt {
  id                String               @id @default(uuid())
  orderId           String
  order             Order                @relation(fields: [orderId], references: [id], onDelete: Cascade)
  provider          PaymentProvider
  mode              String
  status            PaymentAttemptStatus @default(PENDING)
  amount            Decimal              @db.Decimal(14, 2)
  currency          String               @default("VND")
  externalReference String?
  externalOrderId   String?
  checkoutUrl       String?
  qrImageUrl        String?
  qrPayload         Json?
  webhookEventId    String?
  rawResponse       Json?
  paidAt            DateTime?
  expiresAt         DateTime?
  createdAt         DateTime             @default(now())
  updatedAt         DateTime             @updatedAt

  @@index([orderId, provider, status])
  @@index([externalOrderId])
  @@index([externalReference])
  @@index([webhookEventId])
}

model OrderItem {
  id              String   @id @default(uuid())
  orderId         String
  productId       String
  variantId       String?

  // SNAPSHOT fields - stored at order creation time (per D-03)
  productName     String   // Snapshot of product name
  variantName     String?  // Snapshot of variant name
  productCode     String   @db.VarChar(64) // Snapshot of product code
  sku             String   // Snapshot of SKU
  imageUrl        String?  // Snapshot of image

  quantity        Int
  unitPrice       Decimal  @db.Decimal(12, 2)  // Price at order time
  discountPct     Decimal  @db.Decimal(5, 2) @default(0)
  discountAmount  Decimal  @db.Decimal(12, 2) @default(0)
  taxRate         Decimal  @db.Decimal(5, 4) @default(0)
  taxAmount       Decimal  @db.Decimal(14, 2) @default(0)
  totalPrice      Decimal  @db.Decimal(14, 2)  // quantity * unitPrice - discount

  order           Order    @relation(fields: [orderId], references: [id], onDelete: Cascade)

  createdAt       DateTime @default(now())

  @@index([orderId])
}

model Invoice {
  id                  String              @id @default(uuid())
  invoiceNumber       String              @unique
  invoiceDate         DateTime
  status              InvoiceRecordStatus @default(ISSUED)

  orderId             String?             @unique
  order               Order?              @relation(fields: [orderId], references: [id], onDelete: SetNull)
  items               InvoiceItem[]

  supplierName        String
  supplierBusinessId  String?
  supplierVatId       String?
  supplierEmail       String?
  supplierPhone       String?
  supplierAddress     Json?
  supplierWebsite     String?
  supplierLogoUrl     String?
  supplierQrUrl       String?

  recipientName           String
  recipientContactPerson String?
  recipientBusinessId    String?
  recipientVatId        String?
  recipientEmail         String?
  recipientPhone         String?
  recipientAddress       Json?
  deliveryAddress        Json?

  subtotal            Decimal             @db.Decimal(14, 2)
  taxAmount           Decimal             @db.Decimal(14, 2)
  total               Decimal             @db.Decimal(14, 2)
  notes               String?

  createdBy           String?
  updatedBy           String?
  deletedBy           String?
  deletedAt           DateTime?
  createdAt           DateTime            @default(now())
  updatedAt           DateTime            @updatedAt

  @@index([invoiceDate])
  @@index([status])
  @@index([deletedAt])
  @@index([createdAt])
}

model InvoiceItem {
  id              String   @id @default(uuid())
  invoiceId       String
  invoice         Invoice  @relation(fields: [invoiceId], references: [id], onDelete: Cascade)

  productId       String?
  variantId       String?
  description     String
  productCode     String?
  sku             String?
  quantity        Decimal  @db.Decimal(12, 3)
  unitPrice       Decimal  @db.Decimal(12, 2)
  netAmount       Decimal  @db.Decimal(14, 2)
  taxRate         Decimal  @db.Decimal(5, 4) @default(0)
  taxAmount       Decimal  @db.Decimal(14, 2) @default(0)
  totalAmount     Decimal  @db.Decimal(14, 2)
  sortOrder       Int      @default(0)
  createdAt       DateTime @default(now())

  @@index([invoiceId])
}

model OrderStatusHistory {
  id             String      @id @default(uuid())
  orderId        String
  status         OrderStatus
  note           String?
  changedBy      String      // userId of who made the change
  changedByRole  String?     // Role of the user at time of change
  dangerousAction Boolean    @default(false) // True when status change targets COMPLETED/CANCELLED orders

  order          Order       @relation(fields: [orderId], references: [id], onDelete: Cascade)

  createdAt      DateTime    @default(now())

  @@index([orderId])
  @@index([createdAt])
}

model Product {
  id            String             @id @default(uuid())
  sku           String             @unique
  productCode   String             @unique @db.VarChar(64)
  slug          String             @unique
  name          String
  description   String?

  shortDesc     String?

  // Visibility (per D-02)
  visibility    ProductVisibility  @default(WHOLESALE)

  basePrice     Decimal            @db.Decimal(12, 2)

  // Inventory
  trackInventory Boolean           @default(true)
  weight         Decimal?          @db.Decimal(8, 2)  // in grams
  dimensions     Json?             // {length, width, height}
  attributes     Json?

  // Category relation
  categoryId    String
  category      Category           @relation(fields: [categoryId], references: [id])

  // SEO
  metaTitle     String?
  metaDesc      String?

  // Price visibility controls (per D-24)
  showPriceToGuest    Boolean  @default(false)
  showPriceToRetail   Boolean  @default(true)
  showPriceToWholesale Boolean  @default(true)

  // Relations
  variants      ProductVariant[]
  images        ProductImage[]
  // Inventory tracking
  inventory     Inventory?
  inventoryMovements InventoryMovement[] @relation("InventoryMovementProduct")
  cartItems     CartItem[]
  receiptItems  GoodsReceiptItem[]
  shipmentItems OutboundShipmentItem[]

  // Timestamps
  createdAt     DateTime           @default(now())
  updatedAt     DateTime           @updatedAt
  deletedAt     DateTime?

  // Bestseller tracking
  soldCount     Int                @default(0)

  // Per-product tax rate (decimal, e.g. 0.21 for 21%)
  taxRate       Decimal?           @db.Decimal(5, 4)

  // Supplier's own product code / barcode
  supplierCode  String?

  @@index([categoryId])
  @@index([visibility])
  @@index([slug])
  @@index([sku])
  @@index([productCode])
  @@index([deletedAt])
  @@index([soldCount])
}

model ProductImage {
  id          String   @id @default(uuid())
  productId   String
  variantId   String?
  url         String
  altText     String?
  sortOrder   Int      @default(0)
  isPrimary   Boolean  @default(false)

  product     Product         @relation(fields: [productId], references: [id], onDelete: Cascade)
  variant     ProductVariant? @relation(fields: [variantId], references: [id], onDelete: Cascade)

  createdAt   DateTime @default(now())

  @@index([productId])
  @@index([variantId])
}

model ProductVariant {
  id            String   @id @default(uuid())
  productId     String
  productCode   String?  @unique @db.VarChar(64)
  sku           String   @unique
  slug          String   @unique
  name          String
  attributes    Json     // {"color": "Red", "size": "Large"}

  // Optional price override (per D-02)
  basePrice     Decimal? @db.Decimal(12, 2)
  taxRate       Decimal? @db.Decimal(5, 4)

  product       Product  @relation(fields: [productId], references: [id], onDelete: Cascade)
  inventory     Inventory?
  inventoryMovements InventoryMovement[] @relation("InventoryMovementVariant")
  images        ProductImage[]
  cartItems     CartItem[]
  receiptItems  GoodsReceiptItem[]
  shipmentItems OutboundShipmentItem[]

  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  @@index([productId])
  @@index([slug])
}

model Inventory {
  id                String   @id @default(uuid())
  productId         String?  @unique
  variantId         String?  @unique

  quantity          Int      @default(0)
  reservedQty       Int      @default(0)
  lowStockThreshold Int      @default(10)

  product           Product?       @relation(fields: [productId], references: [id], onDelete: Cascade)
  variant           ProductVariant? @relation(fields: [variantId], references: [id], onDelete: Cascade)

  movements         InventoryMovement[]

  updatedAt         DateTime @updatedAt

  @@unique([productId, variantId])
  @@index([productId])
  @@index([variantId])
  @@index([quantity])
}

model InventoryMovement {
  id            String       @id @default(uuid())
  inventoryId   String?
  productId     String?
  variantId     String?
  type          MovementType
  quantity      Int          // positive = in, negative = out
  reference     String?      // order ID, shipment ID, etc.
  note          String?

  inventory     Inventory?      @relation(fields: [inventoryId], references: [id], onDelete: Cascade)
  product       Product?        @relation("InventoryMovementProduct", fields: [productId], references: [id], onDelete: SetNull)
  variant       ProductVariant? @relation("InventoryMovementVariant", fields: [variantId], references: [id], onDelete: SetNull)
  createdBy     String?      // userId
    warehouseStaff   WarehouseStaff? @relation(fields: [warehouseStaffId], references: [id], onDelete: SetNull)
    warehouseStaffId String?

  createdAt     DateTime     @default(now())

  @@index([inventoryId])
  @@index([productId])
  @@index([variantId])
  @@index([productId, createdAt])
  @@index([variantId, createdAt])
  @@index([inventoryId, type, reference])
  @@index([type])
  @@index([type, createdAt])
  @@index([reference])
  @@index([createdAt])
}

model AuditLog {
  id          String      @id @default(uuid())
  entityType  String      // e.g., "Order", "User", "Discount"
  entityId    String
  action      AuditAction
  changes     Json?       // {field: [oldValue, newValue]}

  // Who made the change
  userId      String?
  userEmail   String?
  userRole    String?

  // Context
  ipAddress   String?
  userAgent   String?

  createdAt   DateTime    @default(now())

  @@index([entityType, entityId])
  @@index([userId])
  @@index([action])
  @@index([createdAt])
}

model CtvWithdrawalRequest {
  id                 String           @id @default(uuid())
  ctvId              String
  amount             Decimal          @db.Decimal(14, 2)
  bankName           String
  bankAccountNumber  String
  bankAccountHolder  String
  status             WithdrawalStatus @default(PENDING)
  note               String?
  reviewedAt         DateTime?
  reviewedBy         String?
  createdAt          DateTime         @default(now())
  updatedAt          DateTime         @updatedAt

  ctv                CtvCustomer      @relation(fields: [ctvId], references: [id], onDelete: Cascade)

  // Payouts created from this withdrawal request
  payouts           CtvPayout[]

  @@index([ctvId])
  @@index([ctvId, status, createdAt])
  @@index([status])
  @@index([status, createdAt])
  @@index([createdAt])
}

model CtvPayout {
  id                  String       @id @default(uuid())
  ctvId               String
  withdrawalRequestId String?
  amount              Decimal      @db.Decimal(14, 2)
  bankName            String
  bankAccountNumber   String
  bankAccountHolder   String
  status              PayoutStatus @default(PAID)
  requestedAt         DateTime?
  processedAt         DateTime?
  processedBy         String?
  reversedAt          DateTime?
  reversedBy          String?
  reversalNote        String?
  note                String?
  createdAt           DateTime     @default(now())
  updatedAt           DateTime     @updatedAt

  ctv                CtvCustomer           @relation(fields: [ctvId], references: [id], onDelete: Cascade)
  withdrawalRequest  CtvWithdrawalRequest? @relation(fields: [withdrawalRequestId], references: [id])

  @@index([ctvId])
  @@index([ctvId, status, processedAt])
  @@index([status])
  @@index([status, processedAt])
  @@index([createdAt])
  @@index([withdrawalRequestId, status])
}

// ============================================================
// HINA WMS EXTENSIONS (auto-generated bởi scripts/sync-schema.sh)
// ============================================================
enum GoodsReceiptStatus {
  DRAFT
  CONFIRMED
  CANCELLED
}

enum ReceiptSource {
  MANUAL
  BARCODE
  FILE
}

enum ShipmentStatus {
  PENDING
  PICKING
  PICKED
  PACKING
  PACKED
  HANDED_OVER
  CANCELLED
}

// ============================================================
// MODELS MỚI (WMS-specific)
// ============================================================

model Warehouse {
  id        String   @id @default(uuid())
  code      String   @unique
  name      String
  address   String?
  isDefault Boolean  @default(false)
  isActive  Boolean  @default(true)

  staff     WarehouseStaff[]
  receipts  GoodsReceipt[]
  shipments OutboundShipment[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Supplier {
  id            String   @id @default(uuid())
  code          String?  @unique
  name          String
  contactPerson String?
  phone         String?
  email         String?
  address       String?
  isActive      Boolean  @default(true)

  receipts      GoodsReceipt[]

  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
}

model WarehouseStaff {
  id           String   @id @default(uuid())
  userId       String   @unique
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  employeeCode String   @unique
  warehouseId  String
  warehouse    Warehouse @relation(fields: [warehouseId], references: [id])
  pinHash      String?
  isActive     Boolean  @default(true)

  receipts     GoodsReceipt[]      @relation("ReceivedBy")
  shipments    OutboundShipment[]  @relation("PickedBy")
  movements    InventoryMovement[]

  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  @@index([warehouseId])
  @@index([employeeCode])
}

model GoodsReceipt {
  id            String   @id @default(uuid())
  receiptNumber String   @unique
  warehouseId   String
  warehouse     Warehouse @relation(fields: [warehouseId], references: [id])
  supplierId    String?
  supplier      Supplier? @relation(fields: [supplierId], references: [id])
  receivedById  String
  receivedBy    WarehouseStaff @relation("ReceivedBy", fields: [receivedById], references: [id])
  status        GoodsReceiptStatus @default(DRAFT)
  source        ReceiptSource      @default(MANUAL)
  note          String?
  totalQuantity Int      @default(0)
  totalSku      Int      @default(0)
  completedAt   DateTime?
  cancelledAt   DateTime?

  items         GoodsReceiptItem[]

  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  @@index([warehouseId, createdAt])
  @@index([status])
  @@index([receivedById])
}

model GoodsReceiptItem {
  id               String   @id @default(uuid())
  receiptId        String
  receipt          GoodsReceipt @relation(fields: [receiptId], references: [id], onDelete: Cascade)

  productId        String?
  variantId        String?
  product          Product?       @relation(fields: [productId], references: [id], onDelete: SetNull)
  variant          ProductVariant? @relation(fields: [variantId], references: [id], onDelete: SetNull)

  productCode      String
  productName      String
  sku              String

  expectedQuantity Int      @default(0)
  receivedQuantity Int      @default(0)
  unitCost         Decimal? @db.Decimal(12, 2)
  lotNumber        String?
  expiryDate       DateTime?
  note             String?

  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  @@index([receiptId])
  @@index([productId])
  @@index([variantId])
  @@index([productCode])
}

model OutboundShipment {
  id             String   @id @default(uuid())
  shipmentNumber String   @unique
  orderId        String
  orderNumber    String
  warehouseId    String
  warehouse      Warehouse @relation(fields: [warehouseId], references: [id])
  pickedById     String?
  pickedBy       WarehouseStaff? @relation("PickedBy", fields: [pickedById], references: [id])
  status         ShipmentStatus  @default(PENDING)
  pickedAt       DateTime?
  packedAt       DateTime?
  handedOverAt   DateTime?
  carrierName    String?
  trackingNumber String?
  note           String?

  items          OutboundShipmentItem[]

  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  @@unique([orderId])
  @@index([warehouseId, status])
  @@index([pickedById])
}

model OutboundShipmentItem {
  id            String   @id @default(uuid())
  shipmentId    String
  shipment      OutboundShipment @relation(fields: [shipmentId], references: [id], onDelete: Cascade)

  productId     String?
  variantId     String?
  product       Product?       @relation(fields: [productId], references: [id], onDelete: SetNull)
  variant       ProductVariant? @relation(fields: [variantId], references: [id], onDelete: SetNull)

  productCode   String
  productName   String
  sku           String
  orderQuantity Int
  pickedQuantity Int     @default(0)
  packedQuantity Int     @default(0)

  @@index([shipmentId])
  @@index([productId])
  @@index([variantId])
}
