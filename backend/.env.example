# ============================================
# Hina WMS Backend Environment
# ============================================
# Lưu ý: dùng chung DATABASE_URL và REDIS_URL với hina-e-comm
# ============================================

# Server
NODE_ENV=development
PORT=7777

# Database - CÙNG với hina-e-comm
DATABASE_URL="postgresql://hina_user:hina_password@localhost:5432/hina_e_comm?schema=public"

# Redis - CÙNG với hina-e-comm
REDIS_URL="redis://localhost:6379"

# JWT - CÙNG secret với hina-e-comm để có thể verify token chéo
JWT_SECRET="change-me-to-match-hina-e-comm"
JWT_EXPIRES_IN="15m"
JWT_REFRESH_EXPIRES_IN="7d"

# Webhook từ hina-e-comm
WEBHOOK_SECRET="change-me-shared-with-hina-e-comm"

# SSE
SSE_HEARTBEAT_INTERVAL_MS=25000
