# ============================================================
# Hina-WMS Environment Configuration
# ============================================================
# Copy file này thành `.env` và điền giá trị thật.
# File `.env` KHÔNG được commit (đã có trong .gitignore).
#
# LƯU Ý QUAN TRỌNG:
#   - DATABASE_URL và REDIS_URL phải KHỚP với hina-e-comm
#     vì cả 2 hệ thống dùng CHUNG database & Redis.
#   - JWT_SECRET phải KHỚP với hina-e-comm
#     để token có thể verify chéo giữa 2 hệ thống.
#   - WEBHOOK_SECRET phải khớp với cấu hình bên hina-e-comm
# ============================================================


# ============================================================
# [LOCAL DEV] - dùng khi chạy Docker trên máy cá nhân
# ============================================================

# ----- Database (CÙNG với hina-e-comm) -----
# Lấy giá trị thật từ /home/khang/job/hina-e-comm/.env
DATABASE_URL="postgresql://lotussouvenir:lotussouvenir123654@hina-e-comm-postgres-1:5432/lotussouvenir?schema=public"

# ----- Redis (CÙNG với hina-e-comm) -----
REDIS_URL="redis://:lotussouvenir123654@hina-e-comm-redis-1:6379"

# ----- JWT (KHỚP secret với hina-e-comm) -----
JWT_SECRET="41d5fdb2e4143b733312e80b92c5765fba5505b0125ecf9620ad8639ac71333b"
JWT_EXPIRES_IN="15m"
JWT_REFRESH_EXPIRES_IN="7d"

# ----- Webhook (chia sẻ với hina-e-comm) -----
WEBHOOK_SECRET="change-me-shared-with-hina-e-comm"

# ----- CORS (comma-separated origins được phép) -----
# Frontend WMS + Frontend ecomm
CORS_ORIGINS="http://localhost:4568,http://127.0.0.1:4568,http://localhost:8080,http://127.0.0.1:8080"

# ----- Frontend public API URL -----
NEXT_PUBLIC_API_URL="http://localhost:7777"

# ----- Docker network chung với hina-e-comm -----
HINA_NETWORK_NAME="hina-network"

# ----- Server -----
PORT=7777
NODE_ENV=development

# ----- SSE heartbeat (ms) -----
SSE_HEARTBEAT_INTERVAL_MS=25000


# ============================================================
# [PRODUCTION] - dùng khi deploy lên server thật
# ============================================================
# Uncomment các dòng dưới và comment phần [LOCAL DEV] ở trên
# ------------------------------------------------------------
# DATABASE_URL="postgresql://USER:PASSWORD@DB_HOST:5432/lotussouvenir?schema=public"
# REDIS_URL="redis://:PASSWORD@REDIS_HOST:6379"
# JWT_SECRET="PRODUCTION-JWT-SECRET-MATCH-HINA-ECOMM"
# JWT_EXPIRES_IN="15m"
# JWT_REFRESH_EXPIRES_IN="7d"
# WEBHOOK_SECRET="PRODUCTION-WEBHOOK-SECRET"
# CORS_ORIGINS="https://wms.example.com,https://ecom.example.com"
# NEXT_PUBLIC_API_URL="https://wms-api.example.com"
# HINA_NETWORK_NAME="hina-network"
# PORT=7777
# NODE_ENV=production
# SSE_HEARTBEAT_INTERVAL_MS=25000
